pipeline {
  agent any

  triggers {
      githubPush()
  }

  environment {
    REGISTRY = "${env.REGISTRY ?: 'ghcr.io'}"
    IMAGE_REPO = "${env.IMAGE_REPO ?: 'ghcr.io/aravindsatyan/data-cleaner'}"
    IMAGE_TAG = "${env.BUILD_NUMBER}"
    DOCKER_BUILDKIT = "1"
    KUBE_CONFIG_CRED = "${env.KUBE_CONFIG_CRED ?: ''}"
  }

  stages {
      ...
  }

  post {
      ...
  }
}
